# Cryptofy backend env (example). Do not commit real secrets.

# Database
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# JWT
JWT_SECRET=change-me
# Optional override used by current auth module
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL=15m

# Local vault master key for encrypting secrets at rest (base64 of 32 random bytes).
VAULT_MASTER_KEY_B64=base64-32-bytes

# Server
PORT=3000

# AI Engine
AI_ENGINE_URL=http://localhost:8000
DEV_AI_ENGINE_URL=http://localhost:8000

